page {
  background: linear-gradient(180deg, #edf3ee 0%, #f5f2ec 34%, #f7f5f0 100%);
  color: #2a3933;
  font-size: 30rpx;
  font-family: "PingFang SC", "Hiragino Sans GB", "Source Han Sans SC", "Microsoft YaHei", sans-serif;
}

.container {
  padding: 28rpx 24rpx 44rpx;
}

.card {
  background: rgba(252, 253, 250, 0.94);
  border: 1rpx solid #dfe8e1;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 10rpx 28rpx rgba(77, 94, 84, 0.08);
  margin-bottom: 20rpx;
  animation: card-enter 220ms ease-out both;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 14rpx;
  letter-spacing: 0.3rpx;
}

.label {
  color: #62736b;
  font-size: 26rpx;
}

.value {
  color: #2a3933;
  font-size: 36rpx;
  font-weight: 700;
}

.btn-primary {
  background: linear-gradient(120deg, #6f9582 0%, #7ea294 100%);
  color: #ffffff;
  border-radius: 18rpx;
  font-size: 30rpx;
  height: 92rpx;
  box-shadow: 0 8rpx 20rpx rgba(111, 149, 130, 0.24);
}

.btn-secondary {
  background: #e9f0eb;
  color: #3d5a4f;
  border-radius: 18rpx;
  font-size: 30rpx;
  height: 92rpx;
  margin-top: 14rpx;
}

.btn-primary,
.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-sizing: border-box;
  padding: 0 20rpx;
  font-weight: 600;
}

.btn-primary:active,
.btn-secondary:active {
  opacity: 0.88;
}

.btn-primary::after,
.btn-secondary::after {
  border: none;
}

.tip {
  color: #677a71;
  font-size: 24rpx;
  line-height: 1.7;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.input,
.picker,
.textarea {
  background: #f8fbf8;
  border: 1rpx solid #d7e3da;
  border-radius: 14rpx;
  padding: 16rpx;
  font-size: 30rpx;
  box-shadow: inset 0 1rpx 4rpx rgba(97, 124, 110, 0.05);
}

.textarea {
  min-height: 160rpx;
  width: 100%;
  box-sizing: border-box;
}

.divider {
  height: 1rpx;
  background: #e3ebe5;
  margin: 18rpx 0;
}

.muted {
  color: #8fa09a;
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #eaf2ed;
  color: #4d665b;
  font-size: 24rpx;
}

@keyframes card-enter {
  from {
    opacity: 0;
    transform: translateY(8rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
