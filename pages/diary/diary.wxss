.intro-card {
  background: linear-gradient(140deg, #f8fcf8 0%, #eef5ef 100%);
}

.form-row {
  align-items: center;
}

.form-row .label {
  flex: 1;
  line-height: 1.45;
  padding-right: 14rpx;
}

.input {
  text-align: right;
}

.picker {
  text-align: center;
}

.field-control {
  width: 260rpx;
  min-width: 260rpx;
  height: 76rpx;
  box-sizing: border-box;
}

.picker.field-control {
  display: flex;
  align-items: center;
  justify-content: center;
}

.input.field-control {
  padding-right: 18rpx;
}

.switch-row {
  margin-bottom: 16rpx;
  align-items: center;
}

.switch-row .label {
  flex: 1;
  line-height: 1.45;
  padding-right: 12rpx;
}

.habit-switch {
  transform: scale(0.84);
  transform-origin: right center;
}

.habit-group-title {
  font-size: 24rpx;
  color: #6a7d74;
  margin-bottom: 10rpx;
  margin-top: 4rpx;
}

.inline-tip {
  margin-top: -6rpx;
  margin-bottom: 8rpx;
}
