.history-intro {
  background: linear-gradient(145deg, #f7fbf8 0%, #edf4ef 100%);
}

.history-card {
  padding-bottom: 20rpx;
}

.weekly-summary {
  background: linear-gradient(150deg, #f8fcf8 0%, #edf5ef 100%);
}

.weekly-head {
  align-items: center;
  gap: 14rpx;
}

.weekly-toggle-btn {
  width: 150rpx;
  min-width: 150rpx;
  height: 64rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  padding: 0 10rpx;
  background: #e8f0ea;
  color: #355247;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-sizing: border-box;
  font-weight: 600;
}

.weekly-toggle-btn::after {
  border: none;
}

.table-wrap {
  margin-top: 8rpx;
  border: 1rpx solid #d9e4dc;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f8fbf8;
}

.table-row {
  display: flex;
  align-items: center;
  min-height: 56rpx;
  border-bottom: 1rpx solid #e6eee8;
}

.table-row:last-child {
  border-bottom: none;
}

.table-header {
  background: #edf5ef;
}

.cell {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #4b6157;
  padding: 10rpx 6rpx;
}

.cell-date {
  flex: 1.6;
}

.cell-sleep {
  flex: 1.3;
}

.summary-title {
  font-size: 27rpx;
  color: #40584d;
  font-weight: 600;
  margin-top: 12rpx;
  margin-bottom: 8rpx;
}

.metric-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-top: 12rpx;
  margin-bottom: 10rpx;
}

.metric-item {
  background: #f6faf7;
  border: 1rpx solid #dfe8e1;
  border-radius: 14rpx;
  padding: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.metric-value {
  font-size: 30rpx;
  color: #2e4037;
  font-weight: 600;
}

.action-row {
  gap: 12rpx;
}

.small-btn {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  border-radius: 14rpx;
  background: #e8f0ea;
  color: #355247;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-sizing: border-box;
  padding: 0 14rpx;
  font-weight: 600;
}

.danger {
  background: #f4e9e7;
  color: #844c43;
}

.small-btn::after {
  border: none;
}
