.anchor-core {
  background: linear-gradient(145deg, #f8fcf8 0%, #eef5ef 100%);
}

.anchor-time {
  font-size: 52rpx;
  line-height: 1.1;
  font-weight: 700;
  color: #2d4138;
  margin-bottom: 12rpx;
}

.anchor-row {
  align-items: center;
  margin-bottom: 12rpx;
}

.anchor-picker {
  width: 230rpx;
  min-width: 230rpx;
  height: 74rpx;
  box-sizing: border-box;
}

.hero-card {
  background: linear-gradient(145deg, #f8fcf8 0%, #eef4ef 68%, #eaf0ea 100%);
}

.hero-kicker {
  color: #5d756a;
  font-size: 28rpx;
  letter-spacing: 0.6rpx;
}

.hero-time {
  font-size: 52rpx;
  font-weight: 700;
  color: #2f433a;
  margin: 10rpx 0;
}

.hero-time-record-only {
  font-size: 46rpx;
}

.hero-window {
  color: #4c6158;
  font-size: 28rpx;
}

.hero-reason {
  margin-top: 12rpx;
}

.hero-hint {
  margin-top: 12rpx;
  padding: 14rpx 16rpx;
  border-radius: 14rpx;
  background: rgba(233, 240, 235, 0.9);
  border: 1rpx solid #d7e4db;
  color: #486258;
}

.hero-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.btn-apply {
  margin-top: 16rpx;
  height: 74rpx;
  border-radius: 14rpx;
  background: #3f6d5a;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-apply::after {
  border: none;
}

.metric-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.metric-item {
  background: #f6faf7;
  border: 1rpx solid #dfe8e1;
  border-radius: 16rpx;
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.metric-value {
  font-size: 30rpx;
  color: #2e4037;
  font-weight: 600;
}

.encouragement {
  margin-top: 14rpx;
  padding: 16rpx;
  background: #eef7f1;
  border: 1rpx solid #d5e8da;
  border-radius: 14rpx;
  color: #35584a;
  font-size: 25rpx;
  line-height: 1.6;
}
